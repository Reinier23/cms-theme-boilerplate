<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 630">
  <defs>
    <linearGradient id="heroGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#B71C1C;stop-opacity:0.9"/>
      <stop offset="50%" style="stop-color:#FF6D00;stop-opacity:0.8"/>
      <stop offset="100%" style="stop-color:#2E7D32;stop-opacity:0.7"/>
    </linearGradient>
    <pattern id="spicePattern" x="0" y="0" width="60" height="60" patternUnits="userSpaceOnUse">
      <circle cx="30" cy="30" r="2" fill="rgba(255,255,255,0.1)"/>
      <circle cx="10" cy="10" r="1" fill="rgba(255,255,255,0.05)"/>
      <circle cx="50" cy="20" r="1.5" fill="rgba(255,255,255,0.08)"/>
    </pattern>
  </defs>
  
  <!-- Background -->
  <rect width="1200" height="630" fill="url(#heroGradient)"/>
  <rect width="1200" height="630" fill="url(#spicePattern)"/>
  
  <!-- Main Content Area -->
  <g transform="translate(600, 315)">
    <!-- Central Spoon Icon -->
    <g transform="translate(-40, -60)">
      <ellipse cx="40" cy="20" rx="35" ry="15" fill="rgba(255,255,255,0.9)" rx="35" ry="15"/>
      <rect x="35" y="20" width="10" height="80" fill="rgba(255,255,255,0.9)" rx="5"/>
      <!-- Spice particles on spoon -->
      <circle cx="25" cy="15" r="2" fill="#FF6D00"/>
      <circle cx="40" cy="18" r="1.5" fill="#B71C1C"/>
      <circle cx="50" cy="12" r="1" fill="#2E7D32"/>
    </g>
    
    <!-- Title Text -->
    <text x="0" y="60" text-anchor="middle" fill="white" font-family="serif" font-size="36" font-weight="bold" opacity="0.95">
      Hero Recipe Image
    </text>
    
    <!-- Subtitle -->
    <text x="0" y="90" text-anchor="middle" fill="rgba(255,255,255,0.8)" font-family="sans-serif" font-size="18">
      1200×630 • Professional Food Photography Placeholder
    </text>
    
    <!-- Decorative Elements -->
    <g opacity="0.6">
      <!-- Left pepper -->
      <g transform="translate(-200, -20)">
        <path d="M0,0 Q-10,-20 0,-25 Q15,-25 20,-10 Q25,0 15,20 Q0,25 -5,10 Z" fill="#FF4444"/>
        <circle cx="5" cy="-15" r="2" fill="#00AA00"/>
      </g>
      
      <!-- Right herbs -->
      <g transform="translate(180, -10)">
        <path d="M0,0 Q5,-15 10,-12 Q8,-5 15,0 Q10,15 5,12 Q-2,5 0,0 Z" fill="#228B22"/>
        <path d="M5,0 Q10,-12 15,-8 Q12,-2 18,5 Q15,18 8,15 Q2,8 5,0 Z" fill="#32CD32"/>
      </g>
    </g>
    
    <!-- Corner accents -->
    <circle cx="-250" cy="-120" r="8" fill="rgba(255,255,255,0.2)"/>
    <circle cx="240" cy="100" r="6" fill="rgba(255,255,255,0.15)"/>
    <circle cx="-230" cy="110" r="4" fill="rgba(255,255,255,0.1)"/>
    <circle cx="220" cy="-110" r="5" fill="rgba(255,255,255,0.12)"/>
  </g>
  
  <!-- Overlay texture -->
  <rect width="1200" height="630" fill="rgba(0,0,0,0.1)" style="mix-blend-mode: multiply;"/>
</svg>