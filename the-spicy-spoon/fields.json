        "max": 20,
        "help_text": "Root font size for scaling"
      },
      {
        "name": "type_scale_ratio",
        "label": "Type Scale Ratio",
        "type": "choice",
        "choices": [
          ["1.125", "Minor Second (1.125)"],
          ["1.2", "Minor Third (1.2)"], 
          ["1.25", "Major Third (1.25)"],
          ["1.333", "Perfect Fourth (1.333)"],
          ["1.414", "Augmented Fourth (1.414)"],
          ["1.5", "Perfect Fifth (1.5)"]
        ],
        "default": "1.25",
        "help_text": "Ratio for scaling heading sizes"
      },
      {
        "name": "line_height_base",
        "label": "Base Line Height",
        "type": "number",
        "default": 1.6,
        "min": 1.2,
        "max": 2,
        "step": 0.1,
        "help_text": "Base line height for readability"
      },
      {
        "name": "letter_spacing",
        "label": "Letter Spacing (em)",
        "type": "number",
        "default": 0,
        "min": -0.05,
        "max": 0.1,
        "step": 0.005,
        "help_text": "Adjust character spacing"
      }
    ]
  },
