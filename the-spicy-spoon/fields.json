      },
      {
        "name": "body_font_stack",
        "label": "Body Font Family", 
        "type": "text",
        "default": "'Inter', -apple-system, BlinkMacSystemFont, sans-serif",
        "help_text": "Font for body text and UI elements"
      },
      {
        "name": "base_font_size",
        "label": "Base Font Size (px)",
